# This is an EXAMPLE configuration for running a Mox mail server on NixOS.
# Copy this file to configuration.nix and edit the values marked CHANGEME.
#
# Usage:
#   cp nixos/configuration.nix.example nixos/configuration.nix
#   $EDITOR nixos/configuration.nix
#   sudo nixos-rebuild switch --flake '.#nixos'
#
# See README.md for full documentation.

{ config, pkgs, ... }:

{
  imports =
    [ ./hardware-configuration.nix
      ../modules/mox
    ];

  # Bootloader — adjust for your hardware.
  boot.loader.grub.enable = true;
  boot.loader.grub.device = "/dev/sda";
  boot.loader.grub.useOSProber = true;
  boot.loader.grub.fsIdentifier = "provided";

  networking.hostName = "CHANGEME";
  networking.networkmanager.enable = true;

  # Timezone and locale.
  time.timeZone = "CHANGEME";  # e.g. "Europe/Stockholm", "America/New_York"

  i18n.defaultLocale = "en_US.UTF-8";

  i18n.extraLocaleSettings = {
    LC_ADDRESS = "en_US.UTF-8";
    LC_IDENTIFICATION = "en_US.UTF-8";
    LC_MEASUREMENT = "en_US.UTF-8";
    LC_MONETARY = "en_US.UTF-8";
    LC_NAME = "en_US.UTF-8";
    LC_NUMERIC = "en_US.UTF-8";
    LC_PAPER = "en_US.UTF-8";
    LC_TELEPHONE = "en_US.UTF-8";
    LC_TIME = "en_US.UTF-8";
  };

  # Keyboard layout.
  # services.xserver.xkb.layout = "us";
  # console.keyMap = "us";

  # User account.
  users.users."CHANGEME" = {
    isNormalUser = true;
    description = "Your Name";
    extraGroups = [ "docker" "networkmanager" "wheel" ];
    openssh.authorizedKeys.keys = [
      # Add your SSH public keys here
      "ssh-ed25519 AAAA..."
    ];
    packages = with pkgs; [];
  };

  environment.systemPackages = with pkgs; [
    docker-compose
  ];

  environment.shellAliases = {
    # Convenience alias — adjust path to your clone location.
    apply = "/home/CHANGEME/path/to/flake/scripts/apply-nixos.sh";
  };

  # QEMU guest agent (remove if bare-metal).
  services.qemuGuest.enable = true;

  # SSH: key-only, no root login.
  services.openssh = {
    enable = true;
    openFirewall = true;
    settings = {
      AllowUsers = [ "CHANGEME" ];
      KbdInteractiveAuthentication = false;
      PasswordAuthentication = false;
      PermitRootLogin = "no";
      X11Forwarding = false;
    };
  };

  networking.firewall = {
    enable = true;
    allowedTCPPorts = [ 80 443 ];
    # WireGuard (optional, adjust or remove).
    allowedUDPPorts = [ 51820 21820 ];
  };

  # Require password for sudo. For non-interactive agent use, add:
  #   security.sudo.extraConfig = ''
  #     Defaults timestamp_type=global
  #     Defaults timestamp_timeout=20
  #   '';
  security.sudo.wheelNeedsPassword = true;

  services.fail2ban.enable = true;

  virtualisation.docker = {
    enable = true;
    autoPrune.enable = true;
  };

  nix.settings.experimental-features = [ "nix-command" "flakes" ];

  # --- Mox mail server ---
  # See README.md for full documentation of all options.
  #
  # DNS prerequisites (add before switching MX):
  #   CAA records: 0 issue "letsencrypt.org" on domain, mail, mta-sts, autoconfig
  #   PTR/rDNS: your IP -> mail hostname (set at VPS provider)
  #   DNSSEC: enable at your registrar
  services.mox-mail = {
    enable = true;

    # REQUIRED — set these to your values.
    hostname = "mail.example.com";          # e.g. mail.example.com
    domain = "example.com";                # e.g. example.com
    publicIps = [ "CHANGEME" ];            # e.g. [ "203.0.113.1" ]
    adminAccount = "CHANGEME";             # Mox admin username (postmaster, DMARC, TLSRPT)

    # Certificate settings.
    certName = "mail";                     # Cert file prefix
    certExtraDomains = [                    # Additional SAN domains on the cert.
      "mta-sts.example.com"                # Remove or adjust as needed.
      "autoconfig.example.com"
    ];

    # Internal listener IPs.
    # Add your Docker bridge IP (e.g. "172.18.0.1") if using Pangolin/Traefik.
    internalIps = [ "127.0.0.1" "::1" ];

    acme = {
      email = "admin@example.com";         # Let's Encrypt account email
      # server = "letsencrypt-staging";    # Uncomment to test without rate limits
      envFile = "/var/lib/acme/cloudflare.env";  # DNS API credentials
      # Extra lego flags. Add "--ipv4only" if IPv6 causes LE reachability issues.
      legoExtraFlags = [];
    };

    # SMTP relay for outbound mail (optional).
    relay = {
      enable = false;
      # host = "relay.example.com";        # Uncomment and set if enabling relay
    };

    dkimSelectors = [ "CHANGEME" ];        # e.g. [ "2026a" ]

    # Pangolin/Traefik reverse proxy integration (optional).
    pangolin.enable = false;
  };

  system.stateVersion = "26.05";
}
